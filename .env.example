# JWT signing key — generate a random 32+ character string for production
SECRET_KEY=change-me-to-a-random-secret-key

# SQLite database file path (auto-created on first run)
DATABASE_URL=sqlite:///./collabhub.db

# Google Gemini API key for AI-powered document summarization and search
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760
